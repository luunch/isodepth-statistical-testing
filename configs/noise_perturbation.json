{
  "data": {
    "source": "synthetic",
    "mode": "noise",
    "n_cells": 900,
    "n_genes": 20,
    "sigma": 0.1,
    "seed": 42
  },
  "test": {
    "method": "perturbation_robustness",
    "metric": "nll_gaussian_mse",
    "n_perms": 50,
    "n_nulls": 50,
    "epochs": 500,
    "lr": 0.001,
    "patience": 50,
    "seed": 42,
    "device": "cuda",
    "batch_size": null,
    "n_experts": 1,
    "delta": 0.05,
    "perturb_target": "coordinates",
    "verbose": true
  },
  "output": {
    "out_dir": "results",
    "run_name": "noise_perturbation",
    "save_preds": false,
    "save_perm_stats": true
  }
}
