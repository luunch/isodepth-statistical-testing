{
  "data": {
    "source": "synthetic",
    "mode": "noise",
    "n_cells": 900,
    "n_genes": 20,
    "sigma": 0.1,
    "poly_degree": 1,
    "seed": 42
  },
  "test": {
    "method": "comparison_subsampling_test",
    "metric": "nll_gaussian_mse",
    "n_nulls": 50,
    "epochs": 500,
    "lr": 0.001,
    "patience": 50,
    "seed": 42,
    "device": "cuda",
    "batch_size": null,
    "subset_fractions": [0.1, 0.3, 0.7, 0.9],
    "n_subsets": 10,
    "verbose": true
  },
  "output": {
    "out_dir": "results",
    "run_name": "noise_comparison_subsampling",
    "save_preds": false,
    "save_perm_stats": true
  }
}
