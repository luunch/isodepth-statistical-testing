{
  "data": {
    "source": "synthetic",
    "mode": "radial",
    "n_cells": 900,
    "n_genes": 20,
    "sigma": 0.1,
    "poly_degree": 1,
    "seed": 42
  },
  "test": {
    "method": "comparison_perturbation_test",
    "metric": "nll_gaussian_mse",
    "n_perms": 50,
    "n_nulls": 50,
    "epochs": 1000,
    "lr": 0.001,
    "patience": 50,
    "seed": 42,
    "device": "cuda",
    "delta": [0.05, 0.1, 0.5, 1.0],
    "perturb_target": "coordinates",
    "verbose": true
  },
  "output": {
    "out_dir": "results",
    "run_name": "radial_comparison_perturbation",
    "save_preds": false,
    "save_perm_stats": true
  }
}
